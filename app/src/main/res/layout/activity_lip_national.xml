<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black">

        <com.otaliastudios.cameraview.CameraView
            android:id="@+id/cameraView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cameraDrawHardwareOverlays="true"
            app:cameraEngine="camera2"
            app:cameraFacing="front"
            app:cameraMode="video"
            app:cameraUseDeviceOrientation="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/facePartsOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_drawOnPictureSnapshot="true"
                app:layout_drawOnPreview="true"
                app:layout_drawOnVideoSnapshot="true">

                <TextView
                    android:id="@+id/tv_time_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_50sdp"
                    android:fontFamily="@font/poppins_bold"
                    android:padding="@dimen/_4sdp"
                    android:text="3"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_50ssp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/flagScrollView" />


                <com.titanbbl.funny.face.filter.game.ui.component.custom.FlagScrollView
                    android:id="@+id/flagScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_50sdp"
                    android:layout_marginTop="@dimen/_60sdp"
                    app:layout_constraintTop_toTopOf="parent" />


                <com.titanbbl.funny.face.filter.game.ui.component.filter_activity.prediction.PredictionLayout
                    android:id="@+id/overlayImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_60sdp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_drawOnPictureSnapshot="true"
                    app:layout_drawOnPreview="true"
                    app:layout_drawOnVideoSnapshot="true" />

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/ltv_action"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="576:1024"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:paddingTop="@dimen/_20sdp"
                    app:layout_constraintVertical_bias="0.0"
                    app:lottie_progress="0.1"
                    app:lottie_rawRes="@raw/filter_hand" />


                <!--                <TextView-->
                <!--                    android:id="@+id/tv_answer"-->
                <!--                    android:layout_width="wrap_content"-->
                <!--                    android:layout_height="wrap_content"-->
                <!--                    android:layout_marginTop="@dimen/_50sdp"-->
                <!--                    android:fontFamily="@font/poppins_bold"-->
                <!--                    android:padding="@dimen/_4sdp"-->
                <!--                    android:text="@string/lip_national_is"-->
                <!--                    android:textColor="@color/white"-->
                <!--                    android:textSize="@dimen/_20sdp"-->
                <!--                    android:layout_marginBottom="@dimen/_80sdp"-->
                <!--                    app:layout_constraintBottom_toBottomOf="@+id/ltv_action"-->
                <!--                    app:layout_constraintEnd_toEndOf="parent"-->
                <!--                    app:layout_constraintStart_toStartOf="parent"-->
                <!--                 />-->


            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.otaliastudios.cameraview.CameraView>

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/ic_back_white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/filterHeaderTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:background="@drawable/bg_silhouette_header"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/btnBack">

            <ImageView
                android:id="@+id/ivMusicIconTop"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_music"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/tvFilterNameTop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/poppins_medium"
                android:text="Face Puzzle"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/ivMusicIconTop"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/btnCloseFilterTop"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_close"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/tvFilterNameTop"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@android:color/white" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/rightControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Camera Button -->
            <ImageView
                android:id="@+id/btnCamera"
                android:layout_width="33dp"
                android:layout_height="33dp"
                android:layout_marginBottom="12dp"
                android:src="@drawable/ic_flip_camera" />

            <!-- Timer Container -->
            <ImageView
                android:id="@+id/ivTimer"
                android:layout_width="33dp"
                android:layout_height="33dp"
                android:src="@drawable/ic_timer" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/poppins_medium"
                android:gravity="center"
                android:text="3s"
                android:textColor="@android:color/white"
                android:textSize="12sp" />

        </LinearLayout>


        <TextView
            android:id="@+id/tv_time_rec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/_8sdp"
            android:background="@drawable/bg_silhouette_header"
            android:fontFamily="@font/poppins_regular"
            android:padding="@dimen/_4sdp"
            android:text="00:00"
            android:textColor="@color/white"
            app:layout_constraintBottom_toTopOf="@+id/btnRecord"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/btnRecord"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginBottom="40dp"
            android:src="@drawable/ic_record"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>